SSH_PRIVATE_KEY_PATH=./ipelabor.key
SSH_REMOTE_USER=ssh-user
SSH_REMOTE_HOST=example.com
SSH_REMOTE_PORT=22
SSH_TUNNEL_REMOTE_PORT=7002
SSH_TUNNEL_TARGET_HOST=planka
SSH_TUNNEL_TARGET_PORT=1337

PLANKA_PROD_BASE_URL=http://example.com:7002
PLANKA_PROD_SECRET_KEY=change-me
PLANKA_PROD_DATABASE_USER=user
PLANKA_PROD_DATABASE_PASSWORD=change-me
PLANKA_PROD_DATABASE_DB=planka

PLANKA_DEV_BASE_URL=http://localhost:1337
PLANKA_DEV_DATABASE_URL=postgresql://postgres@postgres/planka
PLANKA_DEV_SECRET_KEY=change-me-dev
PLANKA_DEV_DEFAULT_LANGUAGE=pt-BR
PLANKA_DEV_PROXY_TARGET=http://planka-server:1337
PLANKA_DEV_POSTGRES_DB=planka
PLANKA_DEV_POSTGRES_USER=postgres
PLANKA_DEV_POSTGRES_HOST_AUTH_METHOD=trust

PLANKA_DEFAULT_ADMIN_EMAIL=admin@example.com
PLANKA_DEFAULT_ADMIN_PASSWORD=change-me
PLANKA_DEFAULT_ADMIN_NAME=Administrator
PLANKA_DEFAULT_ADMIN_USERNAME=admin

PLANKA_SMTP_HOST=smtp.example.com
PLANKA_SMTP_PORT=465
PLANKA_SMTP_NAME=Planka
PLANKA_SMTP_SECURE=true
PLANKA_SMTP_TLS_REJECT_UNAUTHORIZED=false
PLANKA_SMTP_USER=mailer@example.com
PLANKA_SMTP_PASSWORD=change-me
PLANKA_SMTP_FROM=Planka <mailer@example.com>
